# =============================================================================
# ZENIA AI MARKETING OS - .gitignore
# =============================================================================

# =============================================================================
# ENVIRONMENT VARIABLES (CRITICAL)
# =============================================================================
.env*
.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# NEVER commit secrets
*.env

# =============================================================================
# NODE MODULES
# =============================================================================
node_modules/

# =============================================================================
# NEXT.JS BUILD OUTPUT
# =============================================================================
.next/
out/
build/

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# OS FILES
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# IDE / EDITOR
# =============================================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# TESTING
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# CACHE
# =============================================================================
.cache/
.vercel/cache/

# =============================================================================
# TYPESCRIPT
# =============================================================================
*.tsbuildinfo

# =============================================================================
# VERCEL
# =============================================================================
.vercel

# =============================================================================
# SUPABASE (LOCAL DEV)
# =============================================================================
.supabase/

# =============================================================================
# UPLOADS / STORAGE (if local)
# =============================================================================
uploads/
public/uploads/

# =============================================================================
# DATABASE
# =============================================================================
*.sqlite
*.db

# =============================================================================
# MISC
# =============================================================================
*.pem
*.key
*.crt

# =============================================================================
# TEMP FILES
# =============================================================================
tmp/
temp/